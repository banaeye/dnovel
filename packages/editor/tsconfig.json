{
  "compilerOptions": {
    "target": "es2023",
    "lib": ["ES2023", "DOM"],
    "module": "esnext",
    "types": ["vite/client"],
    "moduleResolution": "bundler",
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "jsx": "react-jsx",
    "skipLibCheck": true,
    "noEmit": true,
    "paths": {
      "@editor-src/*": ["../../src/editor/*"],
      "@novel-engine/core": ["../core/src/index.ts"]
    }
  },
  "include": ["src", "../../src/editor", "../core/src"]
}
