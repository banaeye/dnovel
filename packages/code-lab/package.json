    "@codemirror/view": "^6.38.8",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-javascript": "^6.2.4",
    "codemirror": "^6.0.2"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "typescript": "~6.0.2",
    "vite": "^8.0.9",
    "vite-plugin-dts": "^4.5.4"
  }
