{
  "name": "@novel-engine/code-lab",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/novel-engine-code-lab.cjs",
  "module": "./dist/novel-engine-code-lab.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/novel-engine-code-lab.mjs",
